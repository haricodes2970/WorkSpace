# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-or-secret-key"

# Database
# Runtime Prisma connection. Use Supabase transaction pooler for Vercel/serverless.
DATABASE_URL="postgresql://postgres.your-project-ref:your-url-encoded-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct/session connection used by Prisma CLI for migrations and schema sync.
DIRECT_URL="postgresql://postgres.your-project-ref:your-url-encoded-password@aws-0-your-region.pooler.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (optional in local development)
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
