generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------
model User {
  id        String    @id @default(uuid()) @db.Uuid
  authId    String    @unique @map("auth_id") @db.Uuid
  email     String    @unique
  name      String?
  avatarUrl String?   @map("avatar_url")
  timezone  String    @default("UTC")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  ideas         Idea[]
  projects      Project[]
  tasks         Task[]
  milestones    Milestone[]
  notes         Note[]
  links         Link[]
  weeklyReviews WeeklyReview[]
  decisions     Decision[]
  timelineEvents TimelineEvent[]
  scopeItems    ScopeItem[]
  risks         ProjectRisk[]
  blockers      Blocker[]

  // Phase 5: knowledge + intelligence
  memories           KnowledgeMemory[]
  insights           InsightSnapshot[]
  retrospectives     Retrospective[]
  graphRelationships GraphRelationship[]
  embeddingJobs      EmbeddingJob[]

  // Phase ∞: intelligent execution layer
  builderProfile     BuilderProfile?
  projectNarratives  ProjectNarrative[]

  // Phase Ω²: platformization
  activityEvents     ActivityEvent[]
  workspaces         Workspace[]
  strategicReviews   StrategicReview[]

  // Phase Σ: OS experience
  session            UserSession?

  @@index([authId])
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Ideas — incubation + maturation stage
// ---------------------------------------------------------------------------
model Idea {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  title            String
  description      String?
  status           IdeaStatus      @default(RAW)
  readinessStatus  ReadinessStatus @default(CAPTURED) @map("readiness_status")
  readinessScore   Float           @default(0) @map("readiness_score")
  tags             String[]        @default([])
  pinned           Boolean         @default(false)
  convertedAt      DateTime?       @map("converted_at")
  projectId        String?         @unique @map("project_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?           @relation(fields: [projectId], references: [id])
  notes                 Note[]
  links                 Link[]
  blocks                IdeaBlock[]
  outgoingRelationships IdeaRelationship[] @relation("SourceRelationships")
  incomingRelationships IdeaRelationship[] @relation("TargetRelationships")
  memories              KnowledgeMemory[]

  @@index([userId])
  @@index([status])
  @@index([readinessStatus])
  @@index([readinessScore])
  @@index([deletedAt])
  @@map("ideas")
}

enum IdeaStatus {
  RAW
  REFINING
  READY
  CONVERTED
  ARCHIVED
}

enum ReadinessStatus {
  CAPTURED
  EXPLORING
  VALIDATING
  PLANNING
  READY
  CONVERTED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// IdeaBlock — structured thinking blocks (one per type per idea)
// ---------------------------------------------------------------------------
model IdeaBlock {
  id        String    @id @default(uuid()) @db.Uuid
  ideaId    String    @map("idea_id") @db.Uuid
  type      BlockType
  content   String    @default("")
  completed Boolean   @default(false)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, type])
  @@index([ideaId])
  @@index([deletedAt])
  @@map("idea_blocks")
}

enum BlockType {
  PROBLEM
  USER_PAIN
  EXISTING_ALTERNATIVES
  MARKET_GAP
  CONSTRAINTS
  RISKS
  ASSUMPTIONS
  MVP_SCOPE
  SUCCESS_METRICS
  EXECUTION_PLAN
  MONETIZATION
  VALIDATION_STRATEGY
}

// ---------------------------------------------------------------------------
// IdeaRelationship — lightweight links between ideas
// ---------------------------------------------------------------------------
model IdeaRelationship {
  id        String           @id @default(uuid()) @db.Uuid
  sourceId  String           @map("source_id") @db.Uuid
  targetId  String           @map("target_id") @db.Uuid
  type      RelationshipType
  createdAt DateTime         @default(now()) @map("created_at")

  source Idea @relation("SourceRelationships", fields: [sourceId], references: [id], onDelete: Cascade)
  target Idea @relation("TargetRelationships", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
  @@map("idea_relationships")
}

enum RelationshipType {
  RELATED
  DEPENDS_ON
  BLOCKS
  DUPLICATE_OF
  SPAWNED_FROM
}

// ---------------------------------------------------------------------------
// Projects
// ---------------------------------------------------------------------------
model Project {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  title       String
  description String?
  status      ProjectStatus @default(PLANNING)
  visibility  Visibility    @default(PRIVATE)
  startDate   DateTime?     @map("start_date")
  targetDate  DateTime?     @map("target_date")
  shippedAt   DateTime?     @map("shipped_at")
  tags        String[]      @default([])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea       Idea?
  tasks      Task[]
  milestones Milestone[]
  notes      Note[]
  links      Link[]
  weeklyReviews WeeklyReview[]
  decisions     Decision[]
  timelineEvents TimelineEvent[]
  scopeItems    ScopeItem[]
  risks         ProjectRisk[]
  blockers      Blocker[]

  // Phase 5: knowledge + intelligence
  memories       KnowledgeMemory[]
  retrospectives Retrospective[]

  // Phase ∞: intelligent execution layer
  narrative      ProjectNarrative?

  // Phase 4: execution intelligence fields
  executionState   ExecutionState @default(PLANNING) @map("execution_state")
  momentumScore    Float          @default(0)        @map("momentum_score")
  scopeHealthScore Float          @default(100)      @map("scope_health_score")

  @@index([userId])
  @@index([status])
  @@index([executionState])
  @@index([deletedAt])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  SHIPPED
  ARCHIVED
}

enum ExecutionState {
  PLANNING
  BUILDING
  VALIDATING
  STABILIZING
  SHIPPING
  MAINTAINING
  PAUSED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// WeeklyReview — structured weekly reflection
// ---------------------------------------------------------------------------
model WeeklyReview {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  weekStarting      DateTime @map("week_starting") @db.Date
  movedForward      String   @default("") @map("moved_forward")
  stalled           String   @default("")
  changed           String   @default("")
  assumptionsFailed String   @default("") @map("assumptions_failed")
  shouldCut         String   @default("") @map("should_cut")
  worthContinuing   Boolean  @default(true) @map("worth_continuing")
  overallRating     Int      @default(3) @map("overall_rating")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, weekStarting])
  @@index([projectId])
  @@map("weekly_reviews")
}

// ---------------------------------------------------------------------------
// Decision — project decision log
// ---------------------------------------------------------------------------
model Decision {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  title        String
  context      String    @default("")
  decision     String
  alternatives String    @default("")
  tradeoffs    String    @default("")
  reversed     Boolean   @default(false)
  reversalNote String?   @map("reversal_note")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deletedAt])
  @@map("decisions")
}

// ---------------------------------------------------------------------------
// TimelineEvent — unified execution history
// ---------------------------------------------------------------------------
model TimelineEvent {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  type        TimelineEventType
  title       String
  description String?
  metadata    Json?
  occurredAt  DateTime          @default(now()) @map("occurred_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, occurredAt(sort: Desc)])
  @@map("timeline_events")
}

enum TimelineEventType {
  TASK_COMPLETED
  MILESTONE_REACHED
  SCOPE_CHANGED
  DECISION_MADE
  REVIEW_COMPLETED
  STATUS_CHANGED
  BLOCKED
  UNBLOCKED
  NOTE_ADDED
  SHIPPED
}

// ---------------------------------------------------------------------------
// ScopeItem — deferred / bucketed feature items
// ---------------------------------------------------------------------------
model ScopeItem {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  title     String
  notes     String?
  bucket    ScopeBucket @default(MVP)
  position  Int         @default(0)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deletedAt])
  @@map("scope_items")
}

enum ScopeBucket {
  MVP
  V1
  LATER
  EXPERIMENTAL
}

// ---------------------------------------------------------------------------
// ProjectRisk — tracked project risks
// ---------------------------------------------------------------------------
model ProjectRisk {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  title       String
  description String?
  severity    RiskSeverity @default(MEDIUM)
  mitigated   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deletedAt])
  @@map("project_risks")
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ---------------------------------------------------------------------------
// Blocker — execution blockers
// ---------------------------------------------------------------------------
model Blocker {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String
  description String?
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("blockers")
}

enum Visibility {
  PRIVATE
  PUBLIC
}

// ---------------------------------------------------------------------------
// Tasks
// ---------------------------------------------------------------------------
model Task {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  projectId   String?    @map("project_id") @db.Uuid
  milestoneId String?    @map("milestone_id") @db.Uuid
  parentId    String?    @map("parent_id") @db.Uuid
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?  @map("due_date")
  completedAt DateTime?  @map("completed_at")
  position    Int        @default(0)
  tags        String[]   @default([])
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  parent    Task?      @relation("SubTasks", fields: [parentId], references: [id])
  subtasks  Task[]     @relation("SubTasks")
  notes     Note[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ---------------------------------------------------------------------------
// Milestones
// ---------------------------------------------------------------------------
model Milestone {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  title       String
  description String?
  status      MilestoneStatus @default(UPCOMING)
  targetDate  DateTime?       @map("target_date")
  completedAt DateTime?       @map("completed_at")
  position    Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([userId])
  @@index([projectId])
  @@index([deletedAt])
  @@map("milestones")
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  MISSED
}

// ---------------------------------------------------------------------------
// Notes
// ---------------------------------------------------------------------------
model Note {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  ideaId    String?   @map("idea_id") @db.Uuid
  projectId String?   @map("project_id") @db.Uuid
  taskId    String?   @map("task_id") @db.Uuid
  title     String?
  content   String
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea    Idea?    @relation(fields: [ideaId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([deletedAt])
  @@map("notes")
}

// ---------------------------------------------------------------------------
// Links
// ---------------------------------------------------------------------------
model Link {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  ideaId    String?   @map("idea_id") @db.Uuid
  projectId String?   @map("project_id") @db.Uuid
  label     String
  url       String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea    Idea?    @relation(fields: [ideaId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([deletedAt])
  @@map("links")
}

// ---------------------------------------------------------------------------
// Phase 5 — Knowledge + Intelligence System
// ---------------------------------------------------------------------------

// KnowledgeMemory — durable capture of learnings, mistakes, discoveries, patterns
// ---------------------------------------------------------------------------
model KnowledgeMemory {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  projectId    String?    @map("project_id") @db.Uuid
  ideaId       String?    @map("idea_id") @db.Uuid
  type         MemoryType
  title        String
  body         String     @default("")
  tags         String[]   @default([])
  significance Int        @default(5)
  pinned       Boolean    @default(false)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])
  idea    Idea?    @relation(fields: [ideaId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([ideaId])
  @@index([type])
  @@index([deletedAt])
  @@map("knowledge_memories")
}

enum MemoryType {
  INSIGHT
  MISTAKE
  DISCOVERY
  PATTERN
  CONSTRAINT
  LEARNING
  BREAKTHROUGH
  PIVOT
}

// GraphRelationship — cross-entity polymorphic connections
// ---------------------------------------------------------------------------
model GraphRelationship {
  id         String                @id @default(uuid()) @db.Uuid
  userId     String                @map("user_id") @db.Uuid
  sourceType EntityType
  sourceId   String                @map("source_id") @db.Uuid
  targetType EntityType
  targetId   String                @map("target_id") @db.Uuid
  type       GraphRelationshipType
  note       String?
  createdAt  DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("graph_relationships")
}

enum EntityType {
  IDEA
  PROJECT
  DECISION
  WEEKLY_REVIEW
  NOTE
  KNOWLEDGE_MEMORY
  MILESTONE
  BLOCKER
  // Phase Ω² — Universal Entity Architecture
  TASK
  SCOPE_ITEM
  RISK
  RETROSPECTIVE
  STRATEGIC_REVIEW
}

enum GraphRelationshipType {
  RELATED_TO
  INSPIRED_BY
  BLOCKED_BY
  DUPLICATES
  EVOLVED_INTO
  REFERENCES
  CONTRADICTS
  DEPENDS_ON
  VALIDATES
  REPLACES
}

// Embedding — pgvector semantic index (read/write via $queryRaw/$executeRaw only)
// ---------------------------------------------------------------------------
model Embedding {
  id         String     @id @default(uuid()) @db.Uuid
  entityType EntityType
  entityId   String     @map("entity_id") @db.Uuid
  content    String
  vector     Unsupported("vector(1536)")?
  model      String     @default("text-embedding-3-small")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([entityType])
  @@map("embeddings")
}

// EmbeddingJob — DB-backed async queue for background embedding
// ---------------------------------------------------------------------------
model EmbeddingJob {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  entityType  EntityType
  entityId    String             @map("entity_id") @db.Uuid
  content     String
  status      EmbeddingJobStatus @default(PENDING)
  attempts    Int                @default(0)
  lastError   String?            @map("last_error")
  createdAt   DateTime           @default(now()) @map("created_at")
  processedAt DateTime?          @map("processed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([status, createdAt])
  @@map("embedding_jobs")
}

enum EmbeddingJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// InsightSnapshot — persisted pattern-detection outputs
// ---------------------------------------------------------------------------
model InsightSnapshot {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        InsightType
  title       String
  body        String
  evidence    Json?
  severity    InsightSeverity @default(INFO)
  dismissed   Boolean         @default(false)
  generatedAt DateTime        @default(now()) @map("generated_at")
  expiresAt   DateTime?       @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed])
  @@index([generatedAt])
  @@map("insight_snapshots")
}

enum InsightType {
  BLOCKER_PATTERN
  SCOPE_INFLATION
  MOMENTUM_DECAY
  ABANDONED_PATTERN
  EXECUTION_BOTTLENECK
  REVIEW_BENEFIT
  DECISION_REVERSAL
  VELOCITY_TREND
  // Phase ∞ — Advisor signals
  FAILURE_RISK
  MVP_DRIFT
  SCOPE_COMPRESSION
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

// Retrospective — structured periodic reflection with frozen snapshot
// ---------------------------------------------------------------------------
model Retrospective {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  projectId   String?           @map("project_id") @db.Uuid
  type        RetrospectiveType
  title       String
  period      String?
  wentWell    String            @default("") @map("went_well")
  wentPoorly  String            @default("") @map("went_poorly")
  learned     String            @default("")
  nextActions String            @default("") @map("next_actions")
  snapshot    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@map("retrospectives")
}

enum RetrospectiveType {
  WEEKLY
  MONTHLY
  PROJECT_CLOSE
  IDEA_AUDIT
  DECISION_REVIEW
  QUARTERLY
}

// ---------------------------------------------------------------------------
// Phase ∞ — Intelligent Execution Layer
// ---------------------------------------------------------------------------

// ProjectNarrative — cached execution narrative per project
model ProjectNarrative {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @unique @map("project_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  summary     String   @default("")
  chapter     String   @default("")
  phase       String   @default("")
  generation  Int      @default(0)
  generatedAt DateTime @default(now()) @map("generated_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("project_narratives")
}

// BuilderProfile — behavioral DNA snapshot for a user
model BuilderProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  data         Json
  generatedAt  DateTime @default(now()) @map("generated_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("builder_profiles")
}

// ---------------------------------------------------------------------------
// Phase Ω² — Platformization & Long-Term Durability
// ---------------------------------------------------------------------------

// ActivityEvent — append-only system-wide event stream for all entities
model ActivityEvent {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  entityType EntityType
  entityId   String       @map("entity_id") @db.Uuid
  kind       ActivityKind
  payload    Json?
  occurredAt DateTime     @default(now()) @map("occurred_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([entityType, entityId, occurredAt(sort: Desc)])
  @@index([kind, occurredAt(sort: Desc)])
  @@map("activity_events")
}

enum ActivityKind {
  CREATED
  UPDATED
  ARCHIVED
  CONVERTED
  LINKED
  REVIEWED
  COMPLETED
  BLOCKED
  RESUMED
  SHIPPED
  DELETED
  RESTORED
  TAGGED
}

// Workspace — scoped operating environment (single-user, isolated)
model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  slug        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
  @@map("workspaces")
}

// StrategicReview — long-horizon reflection: monthly, quarterly, annual
model StrategicReview {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  type        StrategicReviewType
  period      String
  periodStart DateTime            @map("period_start") @db.Date
  periodEnd   DateTime            @map("period_end") @db.Date

  wins        String @default("")
  struggles   String @default("")
  patterns    String @default("")
  nextFocus   String @default("") @map("next_focus")

  snapshot    Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period])
  @@index([userId, type])
  @@map("strategic_reviews")
}

enum StrategicReviewType {
  MONTHLY
  QUARTERLY
  ANNUAL
  PORTFOLIO
  EXECUTION_HEALTH
  IDEA_CEMETERY
}

// Phase Σ: continuity + working set persistence
model UserSession {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  lastActiveProjectId   String?  @map("last_active_project_id") @db.Uuid
  lastVisitedEntityKind String?  @map("last_visited_entity_kind")
  lastVisitedEntityId   String?  @map("last_visited_entity_id") @db.Uuid
  workingSet            Json     @default("[]") @map("working_set")
  sessionData           Json     @default("{}") @map("session_data")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}
